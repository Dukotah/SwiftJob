# ─────────────────────────────────────────────
# SWIFTJOBS — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub — it contains secret keys.
# ─────────────────────────────────────────────

# ── Vercel Postgres ──────────────────────────
# Get these from: Vercel Dashboard → Storage → Your DB → .env.local tab
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ── Auth.js (NextAuth) ───────────────────────
# Generate a secret by running: openssl rand -base64 32
AUTH_SECRET=

# ── Stripe ───────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from: dashboard.stripe.com → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Twilio (SMS) ─────────────────────────────
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# ── Resend (Email) ───────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=invoices@yourdomain.com

# ── Uploadthing (Photo Storage) ──────────────
# Get from: uploadthing.com → Your App → API Keys
UPLOADTHING_SECRET=sk_live_...
UPLOADTHING_APP_ID=

# ── App ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
